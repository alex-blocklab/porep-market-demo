# PoRep Market Demo — Environment Variables
# Copy to .env and fill in after contract deployment

# Filecoin Calibration testnet RPC
VITE_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# WARNING: demo-only private key — never use a mainnet key here
# Anvil dev key (safe for local/testnet demos):
#   address: 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
VITE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Contract addresses — fill in after deploying to Calibration
VITE_POREP_MARKET=0x0000000000000000000000000000000000000000
VITE_SP_REGISTRY=0x0000000000000000000000000000000000000000
VITE_VALIDATOR_FACTORY=0x0000000000000000000000000000000000000000

# Block at which contracts were deployed (speeds up event log scanning)
# Run: cast block-number --rpc-url $VITE_RPC_URL  before deploying, then set this
VITE_DEPLOY_BLOCK=0
